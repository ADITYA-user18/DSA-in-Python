class Solution(object):
    def mergeTwoLists(self, list1, list2):

        head1 =list1
        head2 = list2

        new_ll = ListNode(0)
        dummy = new_ll

        while head1 is not None and head2 is not None:
            if head1.val<=head2.val:
                new_ll.next = head1
                head1 = head1.next

            else:
                new_ll.next = head2
                head2 = head2.next

            new_ll = new_ll.next


        if head1:
            new_ll.next=head1
        else:
            new_ll.next=head2


        return dummy.next
            



        
            
            
