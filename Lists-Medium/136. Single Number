class Solution(object):
    def singleNumber(self, nums):


        d =  {}

        for i in range(len(nums)):
            if nums[i] not in d:
                d[nums[i]]=1

            else:
                d[nums[i]]+=1

        
        for num in nums:
            if d[num]==1:
                return num

        return -1

        
        
